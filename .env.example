# 온전(穩全) API 키 설정 — 이 파일을 .env 로 복사한 뒤 값을 채우세요.
# .env 는 .gitignore 처리되어 커밋되지 않습니다.

# LLM (우선순위: Gemini → Anthropic. 둘 다 없으면 오프라인 MockLLM 데모 모드)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# 모델 교체 (기본: gemini-2.5-flash / anthropic 사용 시 claude-sonnet-5)
ONJEON_MODEL=

# 국토부 실거래가 API (공공데이터포털 data.go.kr 서비스키) — 데이터 파이프라인용
MOLIT_API_KEY=

# RAG 임베딩 모델 (미설정 시 소형 MiniLM — Streamlit Cloud 메모리 제약 대응)
# 로컬 권장: 골든셋 Recall@5 1.000 / MRR 0.961 (2026-07-19 실측)
ONJEON_EMBED_MODEL=intfloat/multilingual-e5-large

# L2 리스크 모델 백엔드 (lr | xgb — 기본 lr, 실데이터 결합 시 xgb 권장)
ONJEON_L2_BACKEND=
